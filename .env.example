PORT=9090

# Upstream source to build from.
GITHUB_MCP_REPO=https://github.com/github/github-mcp-server.git
GITHUB_MCP_REF=main

GITHUB_TOKEN=""
Github_Token=""


# Preferred GHES setting.
# GITHUB_HOST=https://ghe.example.com

# Legacy compatibility also works.
# GITHUB_API_URL=https://ghe.example.com/api/v3

MCP_READ_ONLY=false
MCP_SCOPE_CHALLENGE=false

# Optional server shaping.
# MCP_TOOLSETS=repos,issues
# MCP_TOOLS=get_file_contents,list_issues
# MCP_EXCLUDE_TOOLS=create_issue,create_pull_request

# Optional if exposed behind a reverse proxy.
# MCP_BASE_URL=https://agent-tools.example.com
# MCP_BASE_PATH=/mcp
